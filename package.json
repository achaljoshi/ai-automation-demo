{
  "name": "ai-automation-repo",
  "version": "1.0.0",
  "description": "AI-generated Playwright + Cucumber.js automation tests",
  "scripts": {
    "test": "cucumber-js",
    "test:smoke": "cucumber-js --tags @smoke",
    "test:regression": "cucumber-js --tags @regression",
    "test:headed": "HEADED=true cucumber-js",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.3.1",
    "@cucumber/junit-formatter": "^1.0.0",
    "@cucumber/pretty-formatter": "^1.0.1",
    "@playwright/test": "^1.44.0",
    "playwright": "^1.44.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
